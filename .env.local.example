# Copy this file to .env.local for local development.
# In Vercel, set these under Project Settings > Environment Variables instead.

# Supabase project URL, e.g. https://xxxxxxxx.supabase.co
SUPABASE_URL=

# Supabase "service_role" key (Project Settings > API > service_role).
# NEVER expose this in client-side code or NEXT_PUBLIC_* vars.
SUPABASE_SERVICE_ROLE_KEY=

# Shared secret the Raspberry Pi sends as the "x-api-key" header when
# posting readings to /api/ingest. Generate a long random string, e.g.:
#   openssl rand -hex 32
INGEST_API_KEY=

# Identifier for this sensor/room. Must match DEVICE_ID in the Pi script.
DEFAULT_DEVICE_ID=room-1
