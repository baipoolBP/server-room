# Copy to .env on the Pi (same folder as sensor_reader.py).

# --- Sensor type ---
# Which profiles/<name>.py module to use for reading this sensor. Must also
# be registered in the web app's src/lib/sensorTypes.ts.
SENSOR_TYPE=temp_humidity_xy_md02

# --- RS485 / Modbus ---
# USB-RS485 adapter device path. Find it with: ls /dev/serial/by-id/
SERIAL_PORT=/dev/ttyUSB0
BAUDRATE=9600
SLAVE_ADDRESS=1
# Register addresses + Modbus function code. Defaults verified against real
# XY-MD02 hardware (function code 04 = read input registers). Some
# clones/units expose these as holding registers (function code 03) instead -
# if reads keep failing, scan your sensor (see scan_xy.py) or check its
# datasheet and override READ_FUNCTION_CODE.
HUMIDITY_REGISTER=1
TEMPERATURE_REGISTER=2
READ_FUNCTION_CODE=4

# --- Reporting ---
# How often to read the sensor and send data, in seconds (60-300 recommended).
SEND_INTERVAL_SECONDS=60

# --- Web API (Vercel) ---
API_URL=https://your-project.vercel.app/api/ingest
# Must match INGEST_API_KEY set in the Vercel project's environment variables.
API_KEY=
DEVICE_ID=room-1
# Optional friendly name shown on the dashboard (e.g. "ห้องนอน"). If left
# blank, the dashboard just shows DEVICE_ID.
DEVICE_LABEL=

# --- Local buffering (survives Wi-Fi/internet outages) ---
BUFFER_DB_PATH=./buffer.sqlite3
